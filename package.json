{
  "name": "kymor",
  "version": "2.0.0",
  "description": "Kymor SaaS Key System — MySQL/Prisma Edition",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "build": "vite build",
    "db:push": "npx prisma db push",
